generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model EventLog {
  id        Int      @id @default(autoincrement())
  timestamp DateTime @default(now())
  type      String
  x         Float
  y         Float
  z         Float
  isHandled Boolean  @default(false)
}

